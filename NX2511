-- فرم قتل V7 (تصفية المحميين + مغناطيس)
CreateBtn("فرم قتل V7", 160, function(s)
    _G.farm = s
    if s then
        task.spawn(function()
            while _G.farm do
                local target = nil
                local dist = 800
                for _, v in pairs(workspace:GetChildren()) do
                    if v:IsA("Model") and v ~= Player.Character and v:FindFirstChild("Humanoid") and v.Humanoid.Health > 0 then
                        -- شرط أساسي: ما يكون عنده حماية
                        if not isShielded(v) then
                            local d = (v.PrimaryPart.Position - Player.Character.PrimaryPart.Position).Magnitude
                            if d < dist then target = v; dist = d end
                        end
                    end
                end
                
                if target then
                    while _G.farm and target and target.Humanoid.Health > 0 and not isShielded(target) do
                        -- سحب مغناطيسي لظهر الهدف
                        local goal = target.PrimaryPart.CFrame * CFrame.new(0, 0, 1.8)
                        Player.Character.HumanoidRootPart.CFrame = Player.Character.HumanoidRootPart.CFrame:Lerp(goal, 0.4)
                        
                        RealClick()
                        task.wait(0.02)
                    end
                end
                task.wait(0.1)
            end
        end)
    end
end)

