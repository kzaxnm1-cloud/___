-- [3. محرك الفحص والضرب]

-- فحص الحماية (يتجاهل من فوق رأسه درع أو كلمة حماية)
local function isShielded(model)
    for _, v in pairs(model:GetDescendants()) do
        if v:IsA("BillboardGui") and (v.Name:lower():find("safe") or v.Name:lower():find("protect") or v.Name:lower():find("shield")) then
            return true
        end
        if v:IsA("ImageLabel") and v.Image:find("shield") then return true end
    end
    return false
end

local function RealClick()
    -- يضغط على زر الضرب اللي في الصورة الثانية (الركن السفلي الأيمن)
    local x = Player:GetMouse().ViewSizeX * 0.86
    local y = Player:GetMouse().ViewSizeY * 0.82
    VirtualUser:Button1Down(Vector2.new(x, y))
    task.wait(0.01)
    VirtualUser:Button1Up(Vector2.new(x, y))
end

